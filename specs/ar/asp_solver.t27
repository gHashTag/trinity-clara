    // 4. Query with Restraint
    // 617618619620621622623624625626627628629630631632633634635636637638639640641642643644645646647648649650651652653654655656657658659660661662663664665666667668669670671672673674675676677678679680681682683684685686687688689

    // query_with_restraint(engine: *DatalogEngine, fact_id: u32,
    //                       config: RestraintParams, state: *ExecutionState) -> Trit
    // Query a fact with restraint checking
    // Returns K_UNKNOWN if restraint blocks, actual truth value otherwise
    // Complexity: O(n) where n = number of facts
    pub fn query_with_restraint(
        engine: *DatalogEngine,
        fact_id: u32,
        config: RestraintParams,
        state: *ExecutionState
    ) -> Trit {
        // Track operation
        state.rules_fired = state.rules_fired + 1;

        // Check restraint
        if (should_continue(state.*, config) == K_FALSE) {
            return K_UNKNOWN;  // Restraint blocks query
        }

        // Find fact
        var i : usize = 0;
        while (i < engine.fact_count) {
            const fact = engine.facts[i];
            if (fact.name == @as(u16, @intCast(fact_id))) {
                return fact.args[0];  // Return truth value
            }
            i = i + 1;
        }

        // Fact not found
        return K_UNKNOWN;
    }

    // 690691692693694695696697698699700701702703704705706707708709710711712713714715716717718719720721722723724725726727728729730731732733734735736737738739740741742743744745746747748749750751752753754
    // 5. Consistency Checking
    // 755756757758759760761762763764765766767768769770771772773774775776777778779780781782783784785786787788789790791792793794795796797798799800801802803804805806807808809810811812813814815816817818819820821822823824825826827

    // is_consistent(model: StableModel) -> bool
    // Check if stable model has no contradictions
    // A model is inconsistent if same fact has both K_TRUE and K_FALSE
    // Complexity: O(n^2) where n = model.fact_count
    pub fn is_consistent(model: StableModel) -> bool {
        var i : usize = 0;
        while (i < model.fact_count) {
            const fact_i = model.facts[i];

            var j : usize = 0;
            while (j < model.fact_count) {
                const fact_j = model.facts[j];

                // Same ID with different truth values = contradiction
                if (i != j and fact_i.id == fact_j.id) {
                    // If both are K_TRUE and K_FALSE, inconsistent
                    if ((fact_i.truth == K_TRUE and fact_j.truth == K_FALSE) or
                        (fact_i.truth == K_FALSE and fact_j.truth == K_TRUE)) {
                        return false;
                    }
                }

                j = j + 1;
            }

            i = i + 1;
        }

        return true;
    }

    // 828829830831832833834835836837838839840841842843844845846847848849850851852853854855856857858859860861862863864865866867868869870871872873874875876877878879880881882883884885886887888889890891892
    // 6. Stable Model Computation
    // 893894895896897898899900901902903904905906907908909910911912913914915916917918919920921922923924925926927928929930931932933934935936937938939940941942943944945946947948949950951952953954955956957958959960961962963964965

    // compute_stable_model(engine: *DatalogEngine, rules: []AspRule, count: usize,
    //                       config: AspConfig) -> StableModel
    // Main ASP solver: compute stable model using fixed point iteration
    // Combines datalog inference with NAF checking and restraint
    // Complexity: O(iterations * rules * facts)
    pub fn compute_stable_model(
        engine: *DatalogEngine,
        rules: []AspRule,
        count: usize,
        config: AspConfig
    ) -> StableModel {
        // Initialize result model
        var model : StableModel = StableModel{
            .facts = undefined,
            .fact_count = 0,
            .is_complete = false,
            .iterations = 0,
            .aborted_by_restraint = false,
        };

        // Initialize execution state with quality and GF16 confidence
        const restraint_params = params_for_quality(config.quality);
        var exec_state = ExecutionState{
            .current_depth = 0,
            .rules_fired = 0,
            .current_confidence = config.initial_confidence,  // GF16 from config
            .start_time_ms = 0,  // Simplified
            .quality = config.quality,
        };

        // Add restraint params to state (stored inline for simplicity)
        exec_state.restraint_params = restraint_params;

        // Run fixed point iteration
        const converged = fixed_point_iteration(
            engine,
            rules,
            count,
            &exec_state,
            config.max_iterations
        );

        model.iterations = exec_state.current_depth;
        model.aborted_by_restraint = !converged;
        model.is_complete = converged;

        // Extract facts from engine to model
        var i : usize = 0;
        while (i < engine.fact_count and i < MAX_FACTS) {
            const fact = engine.facts[i];
            model.facts[i] = FactId{
                .id = @as(u32, @intCast(fact.name)),
                .truth = fact.args[0],
            };
            i = i + 1;
        }
        model.fact_count = @as(u8, @intCast(i));

        return model;
    }

    // has_stable_model(engine: *DatalogEngine, rules: []AspRule, count: usize) -> bool
    // Check if ASP program has at least one stable model
    // Uses simplified computation - returns true if consistent model can be found
    // Complexity: O(compute_stable_model)
    pub fn has_stable_model(engine: *DatalogEngine, rules: []AspRule, count: usize) -> bool {
        const config = AspConfig{
            .max_iterations = MAX_ITERATIONS,
            .max_models = 1,
            .quality = .good,  // Use good quality for checking
            .initial_confidence = gf16_encode_f32(1.0),  // Start with high confidence
        };

        const model = compute_stable_model(engine, rules, count, config);

        // Model must be complete and consistent
        return model.is_complete and is_consistent(model);
    }

    // 9669679689699709719729739749759769779789799809819829839849859869879889899909919929939949959969979989991000100110021003100410051006100710081009101010111012101310141015101610171018101910201021102210231024102510261027102810291030
    // TDD - Tests
    // 1031103210331034103510361037103810391040104110421043104410451046104710481049105010511052105310541055105610571058105910601061106210631064106510661067106810691070107110721073107410751076107710781079108010811082108310841085108610871088108910901091109210931094109510961097109810991100110111021103

    test evaluate_naf_all_unknown_succeeds
        // NAF with all unknown facts succeeds
        given engine = datalog_init()
        and unknown_fact = HornClause{ .name = 1, .args = [_]Trit{K_UNKNOWN} ++ [_]Trit{K_UNKNOWN} ** 7, .arg_count = 1 }
        and add_fact(engine, unknown_fact) == true
        and naf_ids = [_]u32{1}
        when result = evaluate_naf(&engine, &naf_ids, 1)
        then result == true

    test evaluate_naf_with_true_fails
        // NAF with a true fact fails
        given engine = datalog_init()
        and true_fact = HornClause{ .name = 1, .args = [_]Trit{K_TRUE} ++ [_]Trit{K_UNKNOWN} ** 7, .arg_count = 1 }
        and add_fact(engine, true_fact) == true
        and naf_ids = [_]u32{1}
        when result = evaluate_naf(&engine, &naf_ids, 1)
        then result == false

    test evaluate_naf_with_false_succeeds
        // NAF with a false fact succeeds (NOT false = true in NAF)
        given engine = datalog_init()
        and false_fact = HornClause{ .name = 1, .args = [_]Trit{K_FALSE} ++ [_]Trit{K_UNKNOWN} ** 7, .arg_count = 1 }
        and add_fact(engine, false_fact) == true
        and naf_ids = [_]u32{1}
        when result = evaluate_naf(&engine, &naf_ids, 1)
        then result == true

    test evaluate_naf_multiple_conditions
        // NAF with multiple conditions checks all
        given engine = datalog_init()
        and fact1 = HornClause{ .name = 1, .args = [_]Trit{K_UNKNOWN} ++ [_]Trit{K_UNKNOWN} ** 7, .arg_count = 1 }
        and fact2 = HornClause{ .name = 2, .args = [_]Trit{K_FALSE} ++ [_]Trit{K_UNKNOWN} ** 7, .arg_count = 1 }
        and add_fact(engine, fact1) == true
        and add_fact(engine, fact2) == true
        and naf_ids = [_]u32{1, 2}
        when result = evaluate_naf(&engine, &naf_ids, 2)
        then result == true  // Neither is K_TRUE

    test fixed_point_converges_no_new_facts
        // Fixed point converges when no new facts
        given engine = datalog_init()
        and rule = Rule{ .antecedent = K_TRUE, .consequent = K_TRUE }
        and fact = HornClause{ .name = 1, .args = [_]Trit{K_FALSE} ++ [_]Trit{K_UNKNOWN} ** 7, .arg_count = 1 }
        and add_fact(engine, fact) == true
        and asp_rule = AspRule{ .base = rule, .naf_ids = [_]u32{0} ** 3, .naf_count = 0 }
        and rules = [_]AspRule{asp_rule}
        and params = params_for_quality(.good)
        and state = ExecutionState{ .current_depth = 0, .rules_fired = 0, .current_confidence = gf16_encode_f32(0.9), .start_time_ms = 0, .quality = .good, .restraint_params = params }
        when result = fixed_point_iteration(&engine, &rules, 1, &state, 100)
        then result == true  // Converged (no new facts from FALSE antecedent)

    test fixed_point_aborts_on_restraint
        // Fixed point aborts when restraint triggers
        given engine = datalog_init()
        and rule = Rule{ .antecedent = K_TRUE, .consequent = K_TRUE }
        and fact = HornClause{ .name = 1, .args = [_]Trit{K_TRUE} ++ [_]Trit{K_UNKNOWN} ** 7, .arg_count = 1 }
        and add_fact(engine, fact) == true
        and asp_rule = AspRule{ .base = rule, .naf_ids = [_]u32{0} ** 3, .naf_count = 0 }
        and rules = [_]AspRule{asp_rule}
        and params = RestraintParams{ .max_depth = 1, .max_rules = 1, .confidence_threshold = gf16_encode_f32(0.5), .timeout_ms = 1000 }
        and state = ExecutionState{ .current_depth = 0, .rules_fired = 0, .current_confidence = gf16_encode_f32(0.4), .start_time_ms = 0, .quality = .good, .restraint_params = params }
        when result = fixed_point_iteration(&engine, &rules, 1, &state, 100)
        then result == false  // Aborted by low confidence

    test query_with_restraint_blocks_on_limit
        // Query returns K_UNKNOWN when restraint blocks
        given engine = datalog_init()
        and fact = HornClause{ .name = 1, .args = [_]Trit{K_TRUE} ++ [_]Trit{K_UNKNOWN} ** 7, .arg_count = 1 }
        and add_fact(engine, fact) == true
        and params = RestraintParams{ .max_depth = 1, .max_rules = 1, .confidence_threshold = gf16_encode_f32(0.9), .timeout_ms = 1000 }
        and state = ExecutionState{ .current_depth = 1, .rules_fired = 2, .current_confidence = gf16_encode_f32(0.5), .start_time_ms = 0, .quality = .good, .restraint_params = params }
        when result = query_with_restraint(&engine, 1, params, &state)
        then result == K_UNKNOWN  // Blocked by restraint

    test query_with_restraint_returns_truth_when_allowed
        // Query returns actual truth when restraint allows
        given engine = datalog_init()
        and fact = HornClause{ .name = 1, .args = [_]Trit{K_TRUE} ++ [_]Trit{K_UNKNOWN} ** 7, .arg_count = 1 }
        and add_fact(engine, fact) == true
        and params = RestraintParams{ .max_depth = 10, .max_rules = 10, .confidence_threshold = gf16_encode_f32(0.5), .timeout_ms = 1000 }
        and state = ExecutionState{ .current_depth = 1, .rules_fired = 2, .current_confidence = gf16_encode_f32(0.9), .start_time_ms = 0, .quality = .good, .restraint_params = params }
        when result = query_with_restraint(&engine, 1, params, &state)
        then result == K_TRUE  // Restraint allows

    test is_consistent_true_no_contradictions
        // Model with no contradictions is consistent
        given model = StableModel{
            .facts = [_]FactId{
                FactId{ .id = 1, .truth = K_TRUE },
                FactId{ .id = 2, .truth = K_FALSE },
                FactId{ .id = 3, .truth = K_UNKNOWN },
            },
            .fact_count = 3,
            .is_complete = true,
            .iterations = 10,
            .aborted_by_restraint = false,
        }
        when result = is_consistent(model)
        then result == true

    test is_consistent_false_has_contradictions
        // Model with same fact having both true and false is inconsistent
        given model = StableModel{
            .facts = [_]FactId{
                FactId{ .id = 1, .truth = K_TRUE },
                FactId{ .id = 1, .truth = K_FALSE },  // Same ID, different truth
                FactId{ .id = 2, .truth = K_TRUE },
            },
            .fact_count = 3,
            .is_complete = true,
            .iterations = 10,
            .aborted_by_restraint = false,
        }
        when result = is_consistent(model)
        then result == false

    test compute_stable_model_simple_program
        // Simple program finds stable model
        given engine = datalog_init()
        and rule = Rule{ .antecedent = K_TRUE, .consequent = K_TRUE }
        and fact = HornClause{ .name = 1, .args = [_]Trit{K_TRUE} ++ [_]Trit{K_UNKNOWN} ** 7, .arg_count = 1 }
        and add_fact(engine, fact) == true
        and asp_rule = AspRule{ .base = rule, .naf_ids = [_]u32{0} ** 3, .naf_count = 0 }
        and rules = [_]AspRule{asp_rule}
        and config = AspConfig{
            .max_iterations = 100,
            .max_models = 1,
            .quality = .good,
            .initial_confidence = gf16_encode_f32(1.0),
        }
        when model = compute_stable_model(&engine, &rules, 1, config)
        then model.is_complete == true and model.aborted_by_restraint == false

    test compute_stable_model_aborted_by_restraint
        // Stable model computation aborts when restraint triggers
        given engine = datalog_init()
        and rule = Rule{ .antecedent = K_TRUE, .consequent = K_TRUE }
        and fact = HornClause{ .name = 1, .args = [_]Trit{K_TRUE} ++ [_]Trit{K_UNKNOWN} ** 7, .arg_count = 1 }
        and add_fact(engine, fact) == true
        and asp_rule = AspRule{ .base = rule, .naf_ids = [_]u32{0} ** 3, .naf_count = 0 }
        and rules = [_]AspRule{asp_rule}
        and config = AspConfig{
            .max_iterations = 100,
            .max_models = 1,
            .quality = .unknown,  // Very restrictive
            .initial_confidence = gf16_encode_f32(0.1),  // Low confidence
        }
        when model = compute_stable_model(&engine, &rules, 1, config)
        then model.aborted_by_restraint == true

    test has_stable_model_true_convergent
        // has_stable_model returns true for convergent program
        given engine = datalog_init()
        and rule = Rule{ .antecedent = K_TRUE, .consequent = K_TRUE }
        and fact = HornClause{ .name = 1, .args = [_]Trit{K_FALSE} ++ [_]Trit{K_UNKNOWN} ** 7, .arg_count = 1 }
        and add_fact(engine, fact) == true
        and asp_rule = AspRule{ .base = rule, .naf_ids = [_]u32{0} ** 3, .naf_count = 0 }
        and rules = [_]AspRule{asp_rule}
        when result = has_stable_model(&engine, &rules, 1)
        then result == true

    test has_stable_model_false_inconsistent
        // has_stable_model returns false for inconsistent program
        // (Simplified: uses engine state which may be empty)
        given engine = datalog_init()
        and rules = [_]AspRule{}
        when result = has_stable_model(&engine, &rules, 0)
        then result == false  // No facts = no stable model

    test asp_config_gf16_initial_confidence
        // AspConfig stores GF16 initial confidence
        given config = AspConfig{
            .max_iterations = 100,
            .max_models = 1,
            .quality = .good,
            .initial_confidence = gf16_encode_f32(0.85),
        }
        then gf16_decode_to_f32(config.initial_confidence) == 0.85

    // 11041105110611071108110911101111111211131114111511161117111811191120112111221123112411251126112711281129113011311132113311341135113611371138113911401141114211431144114511461147114811491150115111521153115411551156115711581159116011611162116311641165116611671168
    // TDD - Invariants
    // 1169117011711172117311741175117611771178117911801181118211831184118511861187118811891190119111921193119411951196119711981199120012011202120312041205120612071208120912101211121212131214121512161217121812191220122112221223122412251226122712281229123012311232123312341235123612371238123912401241

    invariant model_fact_count_within_bounds
        // Fact count is always <= MAX_FACTS
        var model : StableModel = undefined;
        _ = model.fact_count;
        @compileAssert(MAX_FACTS == 32);

    invariant iterations_non_decreasing
        // Iteration count is monotonic (implementation-level check)
        @compileAssert(true);

    invariant complete_model_consistent
        // Complete models should be consistent
        @compileAssert(true);

    invariant aborted_model_incomplete
        // Aborted models are marked incomplete
        @compileAssert(true);

    invariant naf_count_within_bounds
        // NAF count is always <= MAX_NAF
        var rule : AspRule = undefined;
        _ = rule.naf_count;
        @compileAssert(MAX_NAF == 3);

    invariant asp_config_valid_quality
        // Quality level is always valid
        var config : AspConfig = undefined;
        _ = config.quality;

    invariant gf16_confidence_in_range
        // GF16 confidence values are in valid range after decode
        const conf = gf16_encode_f32(0.5);
        const value = gf16_decode_to_f32(conf);
        assert value >= 0.0 and value <= 1.0;

    invariant asp_rule_naf_ids_initialized
        // AspRule naf_ids array is always defined
        var rule : AspRule = undefined;
        _ = rule.naf_ids;

    invariant stable_model_facts_initialized
        // StableModel facts array is always defined
        var model : StableModel = undefined;
        _ = model.facts;

    // 12421243124412451246124712481249125012511252125312541255125612571258125912601261126212631264126512661267126812691270127112721273127412751276127712781279128012811282128312841285128612871288128912901291129212931294129512961297129812991300130113021303130413051306
    // TDD - Benchmarks
    // 1307130813091310131113121313131413151316131713181319132013211322132313241325132613271328132913301331133213331334133513361337133813391340134113421343134413451346134713481349135013511352135313541355135613571358135913601361136213631364136513661367136813691370137113721373137413751376137713781379

    bench evaluate_naf_3_conditions
        // Measure: cycles for evaluate_naf with 3 NAF conditions
        // Target: < 500 cycles
        @setEvalBranchQuota(10000);
        var engine = datalog_init();
        const fact1 = HornClause{ .name = 1, .args = [_]Trit{K_UNKNOWN} ++ [_]Trit{K_UNKNOWN} ** 7, .arg_count = 1 };
        const fact2 = HornClause{ .name = 2, .args = [_]Trit{K_FALSE} ++ [_]Trit{K_UNKNOWN} ** 7, .arg_count = 1 };
        const fact3 = HornClause{ .name = 3, .args = [_]Trit{K_UNKNOWN} ++ [_]Trit{K_UNKNOWN} ** 7, .arg_count = 1 };
        _ = add_fact(&engine, fact1);
        _ = add_fact(&engine, fact2);
        _ = add_fact(&engine, fact3);
        const naf_ids = [_]u32{1, 2, 3};
        var result : bool = false;
        for (0..1000) |_| {
            result = evaluate_naf(&engine, &naf_ids, 3);
        }
        _ = result;

    bench fixed_point_iteration_10_iter
        // Measure: cycles for fixed point iteration (up to 10)
        // Target: < 2000 cycles
        @setEvalBranchQuota(10000);
        var engine = datalog_init();
        const rule = Rule{ .antecedent = K_TRUE, .consequent = K_UNKNOWN };
        const fact = HornClause{ .name = 1, .args = [_]Trit{K_FALSE} ++ [_]Trit{K_UNKNOWN} ** 7, .arg_count = 1 };
        _ = add_fact(&engine, fact);
        const asp_rule = AspRule{ .base = rule, .naf_ids = [_]u32{0} ** 3, .naf_count = 0 };
        const rules = [_]AspRule{asp_rule};
        const params = params_for_quality(.good);
        var state = ExecutionState{
            .current_depth = 0,
            .rules_fired = 0,
            .current_confidence = gf16_encode_f32(0.9),
            .start_time_ms = 0,
            .quality = .good,
            .restraint_params = params,
        };
        var result : bool = false;
        for (0..1000) |_| {
            // Reset engine
            engine.fact_count = 1;
            result = fixed_point_iteration(&engine, &rules, 1, &state, 10);
        }
        _ = result;

    bench compute_stable_model_10_rules
        // Measure: cycles for compute_stable_model with 10 rules
        // Target: < 5000 cycles
        @setEvalBranchQuota(10000);
        var engine = datalog_init();
        const base_rule = Rule{ .antecedent = K_TRUE, .consequent = K_UNKNOWN };
        var rules : [10]AspRule = undefined;
        for (0..10) |i| {
            rules[i] = AspRule{
                .base = base_rule,
                .naf_ids = [_]u32{0} ** 3,
                .naf_count = 0,
            };
        }
        const fact = HornClause{ .name = 1, .args = [_]Trit{K_FALSE} ++ [_]Trit{K_UNKNOWN} ** 7, .arg_count = 1 };
        _ = add_fact(&engine, fact);
        const config = AspConfig{
            .max_iterations = 50,
            .max_models = 1,
            .quality = .good,
            .initial_confidence = gf16_encode_f32(1.0),
        };
        var model : StableModel = undefined;
        for (0..100) |_| {
            // Reset engine
            engine.fact_count = 1;
            model = compute_stable_model(&engine, &rules, 10, config);
        }
        _ = model;

    bench is_consistent_16_facts
        // Measure: cycles for is_consistent with 16 facts
        // Target: < 1000 cycles (O(n^2) with n=16)
        @setEvalBranchQuota(10000);
        const model = StableModel{
            .facts = [_]FactId{
                FactId{ .id = 1, .truth = K_TRUE }, FactId{ .id = 2, .truth = K_FALSE },
                FactId{ .id = 3, .truth = K_UNKNOWN }, FactId{ .id = 4, .truth = K_TRUE },
                FactId{ .id = 5, .truth = K_FALSE }, FactId{ .id = 6, .truth = K_UNKNOWN },
                FactId{ .id = 7, .truth = K_TRUE }, FactId{ .id = 8, .truth = K_FALSE },
                FactId{ .id = 9, .truth = K_UNKNOWN }, FactId{ .id = 10, .truth = K_TRUE },
                FactId{ .id = 11, .truth = K_FALSE }, FactId{ .id = 12, .truth = K_UNKNOWN },
                FactId{ .id = 13, .truth = K_TRUE }, FactId{ .id = 14, .truth = K_FALSE },
                FactId{ .id = 15, .truth = K_UNKNOWN }, FactId{ .id = 16, .truth = K_TRUE },
            },
            .fact_count = 16,
            .is_complete = true,
            .iterations = 50,
            .aborted_by_restraint = false,
        };
        var result : bool = false;
        for (0..1000) |_| {
            result = is_consistent(model);
        }
        _ = result;

    bench query_with_restraint_latency
        // Measure: cycles for query_with_restraint
        // Target: < 200 cycles
        @setEvalBranchQuota(10000);
        var engine = datalog_init();
        const fact = HornClause{ .name = 1, .args = [_]Trit{K_TRUE} ++ [_]Trit{K_UNKNOWN} ** 7, .arg_count = 1 };
        _ = add_fact(&engine, fact);
        const params = params_for_quality(.good);
        var state = ExecutionState{
            .current_depth = 1,
            .rules_fired = 1,
            .current_confidence = gf16_encode_f32(0.9),
            .start_time_ms = 0,
            .quality = .good,
            .restraint_params = params,
        };
        var result : Trit = K_UNKNOWN;
        for (0..1000) |_| {
            result = query_with_restraint(&engine, 1, params, &state);
        }
        _ = result;
}
