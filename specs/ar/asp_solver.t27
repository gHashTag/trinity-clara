    use base::types;            // Trit enum: .neg, .zero, .pos
    use ar::ternary_logic;      // K_FALSE, K_UNKNOWN, K_TRUE, Rule, is_restraint
    use ar::datalog_engine;     // DatalogEngine, HornClause, datalog_init, etc.
    use ar::restraint;          // RestraintParams, ExecutionState, params_for_quality
    use numeric::gf16;          // GF16 for confidence (NUMERIC-STANDARD-001)

    // 138139140141142143144145146147148149150151152153154155156157158159160161162163164165166167168169170171172173174175176177178179180181182183184185186187188189190191192193194195196197198199200201202
    // 1. ASP Core Types
    // 203204205206207208209210211212213214215216217218219220221222223224225226227228229230231232233234235236237238239240241242243244245246247248249250251252253254255256257258259260261262263264265266267268269270271272273274275

    // MAX_NAF: Maximum number of NAF conditions per rule
    pub const MAX_NAF : u8 = 3;
    // MAX_FACTS: Maximum facts in stable model
    pub const MAX_FACTS : u8 = 32;
    // MAX_ITERATIONS: Default max iterations for fixed point
    pub const MAX_ITERATIONS : u16 = 1000;

    // AspRule: Horn clause with Negation as Failure
    // Represents: IF body AND NOT naf_ids[0] AND ... AND NOT naf_ids[n-1] THEN head
    // NAF semantics: rule fires only if all NAF conditions are NOT K_TRUE
    pub const AspRule = struct {
        base : Rule,            // Horn clause body (from ternary_logic)
        naf_ids : [MAX_NAF]u32, // Fact IDs that must NOT be K_TRUE
        naf_count : u8,         // Actual number of NAF conditions (0-MAX_NAF)
    };

    // FactId: Fact identifier with truth value
    // Associates a fact ID with its Kleene truth value
    pub const FactId = struct {
        id : u32,    // Fact identifier
        truth : Trit, // Truth value: K_FALSE, K_UNKNOWN, K_TRUE
    };

    // StableModel: Result of ASP solver computation
    // Contains all derived facts and convergence info
    pub const StableModel = struct {
        facts : [MAX_FACTS]FactId,  // Derived facts
        fact_count : u8,            // Number of facts in model
        is_complete : bool,         // Whether model is complete (all facts derived)
        iterations : u16,           // Iterations to reach stable model
        aborted_by_restraint : bool, // True if computation was aborted by restraint
    };

    // AspConfig: Configuration for ASP solver
    pub const AspConfig = struct {
        max_iterations : u16,         // Max iterations for fixed point
        max_models : u8,              // Max models to generate (for multi-model ASP)
        quality : QualityLevel,       // Quality level for restraint (from ar::restraint)
        initial_confidence : GF16,    // Initial confidence (GF16 encoded)
    };

    // AspState: State for ASP computation with restraint
    pub const AspState = struct {
        engine : DatalogEngine,       // Datalog engine for inference
        exec_state : ExecutionState,  // Execution state from ar::restraint
        restraint_params : RestraintParams, // Restraint parameters (with GF16)
    };

    // 276277278279280281282283284285286287288289290291292293294295296297298299300301302303304305306307308309310311312313314315316317318319320321322323324325326327328329330331332333334335336337338339340
    // 2. NAF (Negation as Failure) Evaluation
    // 341342343344345346347348349350351352353354355356357358359360361362363364365366367368369370371372373374375376377378379380381382383384385386387388389390391392393394395396397398399400401402403404405406407408409410411412413

    // evaluate_naf(engine: *DatalogEngine, naf_ids: []u32, count: usize) -> bool
    // Evaluate NAF conditions: return true if ALL NAF conditions are NOT K_TRUE
    // NAF semantics: NOT p means "p cannot be proven" (p != K_TRUE)
    // This is "negation as failure" - negation succeeds only if atom is not true
    // Complexity: O(n) where n = count
    pub fn evaluate_naf(engine: *DatalogEngine, naf_ids: []u32, count: usize) -> bool {
        var i : usize = 0;
        while (i < count) {
            const fact_id = naf_ids[i];

            // Find fact by ID in engine
            var found : bool = false;
            var fact_truth : Trit = K_UNKNOWN;

            var j : usize = 0;
            while (j < engine.fact_count) {
                const fact = engine.facts[j];
                // Simplified: fact name is used as ID
                if (fact.name == @as(u16, @intCast(fact_id))) {
                    // Get truth from first argument
                    fact_truth = fact.args[0];
                    found = true;
                    break;
                }
                j = j + 1;
            }

            // If fact is K_TRUE, NAF fails
            if (found and fact_truth == K_TRUE) {
                return false;
            }

            i = i + 1;
        }

        // All NAF conditions satisfied (none are K_TRUE)
        return true;
    }

