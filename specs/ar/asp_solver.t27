// t27/specs/ar/asp_solver.t27
// Answer Set Programming with Restraint for CLARA
// Negation as Failure (NAF) with Kleene K3 semantics
// phi^2 + 1/phi^2 = 3 | TRINITY

module AspSolver {
    // 012345678910111213141516171819202122232425262728293031323334353637383940414243444546474849505152535455565758596061626364
