    // 3. Fixed Point Iteration with Restraint
    // 479480481482483484485486487488489490491492493494495496497498499500501502503504505506507508509510511512513514515516517518519520521522523524525526527528529530531532533534535536537538539540541542543544545546547548549550551

    // fixed_point_iteration(engine: *DatalogEngine, rules: []AspRule, count: usize,
    //                       tracker: *ExecutionState, max_iter: u16) -> bool
    // Run fixed point iteration for ASP with restraint checking
    // Applies rules repeatedly until no new facts or restraint triggers
    // Returns true if converged to stable model, false if aborted by restraint
    // Complexity: O(iterations * rules * facts)
    pub fn fixed_point_iteration(
        engine: *DatalogEngine,
        rules: []AspRule,
        count: usize,
        tracker: *ExecutionState,
        max_iter: u16
    ) -> bool {
        var converged : bool = false;
        var iteration : u16 = 0;

        // Import from ar::datalog_engine
        use datalog_solve;

        while (iteration < max_iter) {
            // Check restraint before each iteration
            if (should_continue(tracker.*, tracker.restraint_params) == K_FALSE) {
                // Restraint triggered - abort
                return false;
            }

            // Record operation
            tracker.rules_fired = tracker.rules_fired + 1;

            // Run one step of datalog inference
            const new_facts = datalog_solve(engine);

            // Check for convergence (no new facts derived)
            if (new_facts == 0) {
                converged = true;
                break;
            }

            // Increment depth for next iteration
            tracker.current_depth = tracker.current_depth + 1;
            iteration = iteration + 1;
        }

        return converged;
    }

