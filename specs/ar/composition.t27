// Helper types for composition
const CNNResult = struct {
    decision : Trit,
    probability : f32,
};

const MLPResult = struct {
    probability : f32,
};

const TransformerResult = struct {
    decision : Trit,
    attention_scores : [10]f32,
};

const RLResult = struct {
    probability : f32,
    value : f32,
};

const ARResult = struct {
    decision : Trit,
    confidence : GF16,
    trace : ProofTrace,
};

const null_rules = [_]HornClause{};
const FormatStyle = enum { natural, fitch, compact };
