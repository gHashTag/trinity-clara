{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "spec_name": "datalog_engine",
  "spec_file": "specs/ar/datalog_engine.t27",
  "ring": 20,
  "description": "Forward-chaining Datalog with O(n) complexity",
  "generated": "2026-04-08",
  "phi_identity": "phi² + 1/phi² = 3 | TRINITY",

  "test_cases": [
    {
      "name": "simple_forward_chain",
      "description": "A -> B, B -> C, A therefore C",
      "facts": ["A"],
      "rules": [
        {"head": "B", "body": ["A"]},
        {"head": "C", "body": ["B"]}
      ],
      "expected_conclusions": ["B", "C"]
    },
    {
      "name": "multiple_rules_same_head",
      "description": "A -> B, C -> B, {A, C} therefore B",
      "facts": ["A", "C"],
      "rules": [
        {"head": "B", "body": ["A"]},
        {"head": "B", "body": ["C"]}
      ],
      "expected_conclusions": ["B"]
    },
    {
      "name": "transitive_chain",
      "description": "A -> B, B -> C, C -> D, A therefore D",
      "facts": ["A"],
      "rules": [
        {"head": "B", "body": ["A"]},
        {"head": "C", "body": ["B"]},
        {"head": "D", "body": ["C"]}
      ],
      "expected_conclusions": ["B", "C", "D"]
    },
    {
      "name": "empty_body_fact",
      "description": "Fact as rule with empty body",
      "facts": [],
      "rules": [
        {"head": "A", "body": []}
      ],
      "expected_conclusions": ["A"]
    },
    {
      "name": "no_match_from_facts",
      "description": "A -> B, but only C is known",
      "facts": ["C"],
      "rules": [
        {"head": "B", "body": ["A"]}
      ],
      "expected_conclusions": []
    }
  ],

  "invariants": [
    {
      "name": "monotonic_growth",
      "description": "Facts only grow, never shrink",
      "property": "|derived_facts[i]| <= |derived_facts[i+1]|"
    },
    {
      "name": "fixed_point_termination",
      "description": "Algorithm reaches fixed point",
      "property": "When no new facts derived, algorithm terminates"
    }
  ],

  "benchmarks": [
    {
      "name": "forward_chain_linear",
      "description": "O(n) complexity verification",
      "target_cycles": 5000,
      "fact_count": 100,
      "rule_count": 100
    }
  ]
}
