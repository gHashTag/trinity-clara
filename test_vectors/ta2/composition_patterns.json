{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "spec_name": "composition_patterns",
  "spec_file": "specs/ar/composition.t27",
  "ring": 24,
  "description": "ML+AR Composition Patterns with VSA Integration",
  "generated": "2026-04-08",
  "phi_identity": "phi² + 1/phi² = 3 | TRINITY",

  "test_cases": [
    {
      "name": "neural_symbolic_hybrid",
      "pattern": "NEURAL_SYMBOLIC_HYBRID",
      "description": "Neural feature extraction → VSA encoding → AR reasoning",
      "pipeline": {
        "stages": [
          {
            "component": "NeuralEncoder",
            "operation": "extract_features",
            "output_dim": 1024
          },
          {
            "component": "VSAEncoder",
            "operation": "encode_to_trits",
            "input_dim": 1024,
            "output_dim": 1024
          },
          {
            "component": "AREngine",
            "operation": "forward_chain",
            "max_steps": 10
          },
          {
            "component": "XAIModule",
            "operation": "generate_explanation",
            "max_steps": 10
          }
        ],
        "quality_threshold": 0.7
      },
      "expected_output": "AR conclusion with ≤10 step explanation, quality >= 0.7"
    },
    {
      "name": "vsa_semantic_memory_retrieval",
      "pattern": "VSA_SEMANTIC_MEMORY",
      "description": "Query → VSA similarity search → Retrieval",
      "pipeline": {
        "stages": [
          {
            "component": "QueryEncoder",
            "operation": "encode_query",
            "vsa_dim": 1024
          },
          {
            "component": "VSASimilarity",
            "operation": "similarity_search",
            "metric": "cosine",
            "top_k": 5
          },
          {
            "component": "Retrieval",
            "operation": "fetch_context",
            "threshold": 0.5
          },
          {
            "component": "AREngine",
            "operation": "reason_with_context"
          }
        ],
        "similarity_threshold": 0.5
      },
      "expected_output": "Context retrieved from memory, AR conclusion derived"
    },
    {
      "name": "vsa_sequence_encoding",
      "pattern": "VSA_SEQUENCE_ENCODING",
      "description": "Sequence → VSA position-aware encoding → Order-sensitive reasoning",
      "pipeline": {
        "stages": [
          {
            "component": "SequenceEncoder",
            "operation": "encode_sequence",
            "vsa_dim": 1024,
            "method": "permute"
          },
          {
            "component": "VSAProbe",
            "operation": "probe_position",
            "position": 0
          },
          {
            "component": "AREngine",
            "operation": "temporal_reasoning"
          }
        ],
        "max_sequence_length": 10
      },
      "expected_output": "Position-aware reasoning, order-sensitive output"
    },
    {
      "name": "neural_vsa_attention",
      "pattern": "NEURAL_VSA_ATTENTION",
      "description": "Self-attention → VSA bind/unbind for associative memory",
      "pipeline": {
        "stages": [
          {
            "component": "Transformer",
            "operation": "self_attention",
            "num_heads": 8
          },
          {
            "component": "VSABind",
            "operation": "bind_key_value",
            "vsa_dim": 1024
          },
          {
            "component": "VSAUnbind",
            "operation": "retrieve_value",
            "similarity_threshold": 0.8
          },
          {
            "component": "AREngine",
            "operation": "deduce_with_retrieval"
          }
        ]
      },
      "expected_output": "Value retrieved with similarity >= 0.8"
    },
    {
      "name": "vsa_bundle_superposition",
      "pattern": "VSA_BUNDLE_SUPERPOSITION",
      "description": "Multiple concepts → VSA bundle → Set-like reasoning",
      "pipeline": {
        "stages": [
          {
            "component": "ConceptEncoder",
            "operation": "encode_concepts",
            "num_concepts": 5,
            "vsa_dim": 1024
          },
          {
            "component": "VSABundle",
            "operation": "bundle3",
            "vsa_dim": 1024
          },
          {
            "component": "VSASimilarity",
            "operation": "probe_concepts",
            "concept_index": 0
          },
          {
            "component": "AREngine",
            "operation": "set_reasoning"
          }
        ],
        "recovery_threshold": 0.6
      },
      "expected_output": "Individual concepts recoverable from bundle with similarity >= 0.6"
    },
    {
      "name": "mlp_vsa_hybrid_classification",
      "pattern": "MLP_VSA_HYBRID",
      "description": "MLP forward pass → VSA encoding → Rule-based classification",
      "pipeline": {
        "stages": [
          {
            "component": "MLP",
            "operation": "forward_pass",
            "hidden_layers": [256, 128],
            "activation": "relu"
          },
          {
            "component": "VSAEncoder",
            "operation": "encode_logits",
            "vsa_dim": 1024
          },
          {
            "component": "RuleEngine",
            "operation": "match_class_rules",
            "confidence_threshold": 0.7
          },
          {
            "component": "Restraint",
            "operation": "check_confidence",
            "min_confidence": 0.7
          }
        ],
        "confidence_threshold": 0.7
      },
      "expected_output": "Classification with confidence >= 0.7"
    },
    {
      "name": "vsa_analogy_reasoning",
      "pattern": "VSA_ANALOGY",
      "description": "A:B :: C:? using VSA bind/unbind operations",
      "pipeline": {
        "stages": [
          {
            "component": "VSAEncoder",
            "operation": "encode_entities",
            "entities": ["A", "B", "C"],
            "vsa_dim": 1024
          },
          {
            "component": "VSABind",
            "operation": "bind_a_b",
            "a": "A",
            "b": "B"
          },
          {
            "component": "VSAUnbind",
            "operation": "unbind_from_c",
            "bound": "A_BIND_B",
            "key": "C"
          },
          {
            "component": "VSASimilarity",
            "operation": "find_best_match",
            "candidates": ["D", "E", "F"]
          }
        ]
      },
      "expected_output": "Best analogical match with highest similarity"
    },
    {
      "name": "rl_vsa_policy_encoding",
      "pattern": "RL_VSA_POLICY",
      "description": "RL policy network → VSA state encoding → AR constraint checking",
      "pipeline": {
        "stages": [
          {
            "component": "RLPolicyNet",
            "operation": "select_action",
            "state_dim": 256,
            "action_dim": 10
          },
          {
            "component": "VSAEncoder",
            "operation": "encode_state_action",
            "vsa_dim": 1024
          },
          {
            "component": "RuleEngine",
            "operation": "check_safety_constraints",
            "safety_critical": true
          },
          {
            "component": "Guardrails",
            "operation": "allow_or_block",
            "policy": "safe_only"
          }
        ],
        "safety_critical": true
      },
      "expected_output": "Action allowed only if all safety constraints satisfied"
    },
    {
      "name": "vsa_hierarchical_reasoning",
      "pattern": "VSA_HIERARCHICAL",
      "description": "Hierarchical concepts → Nested VSA bind → Multi-level reasoning",
      "pipeline": {
        "stages": [
          {
            "component": "ConceptEncoder",
            "operation": "encode_hierarchy",
            "levels": ["category", "subcategory", "item"],
            "vsa_dim": 1024
          },
          {
            "component": "VSABind",
            "operation": "nested_bind",
            "bind_order": ["category", "subcategory", "item"]
          },
          {
            "component": "VSAUnbind",
            "operation": "hierarchical_retrieve",
            "level": "subcategory"
          },
          {
            "component": "AREngine",
            "operation": "taxonomic_reasoning"
          }
        ],
        "hierarchy_depth": 3
      },
      "expected_output": "Correct retrieval at each hierarchy level"
    },
    {
      "name": "neural_vsa_explainable_decision",
      "pattern": "NEURAL_VSA_XAI",
      "description": "Neural decision → VSA trace → Explainable AR",
      "pipeline": {
        "stages": [
          {
            "component": "NeuralModel",
            "operation": "predict",
            "model_type": "classifier"
          },
          {
            "component": "VSAEncoder",
            "operation": "encode_attention_weights",
            "vsa_dim": 1024
          },
          {
            "component": "VSABind",
            "operation": "bind_decision_attribution"
          },
          {
            "component": "XAIModule",
            "operation": "generate_explanation",
            "max_steps": 10,
            "include_attribution": true
          }
        ],
        "max_explanation_steps": 10
      },
      "expected_output": "Decision explanation with attribution in ≤10 steps"
    },
    {
      "name": "coptic_27dim_symbolic_operations",
      "pattern": "COPTIC_SYMBOLIC",
      "description": "Coptic alphabet VSA (27-dim) → Symbolic operations",
      "pipeline": {
        "stages": [
          {
            "component": "CopticEncoder",
            "operation": "encode_letters",
            "alphabet_size": 27,
            "vsa_dim": 27
          },
          {
            "component": "CopticBind",
            "operation": "bind_letter_sequence"
          },
          {
            "component": "CopticBundle",
            "operation": "bundle_words",
            "bundle_method": "bundle3"
          },
          {
            "component": "AREngine",
            "operation": "linguistic_reasoning"
          }
        ],
        "vsa_dim": 27,
        "alphabet_size": 27
      },
      "expected_output": "Linguistic reasoning over 27-dim Coptic space"
    },
    {
      "name": "vsa_noise_robust_reasoning",
      "pattern": "VSA_NOISE_ROBUST",
      "description": "Noisy input → VSA bundle3 → Robust reasoning",
      "pipeline": {
        "stages": [
          {
            "component": "NoiseInjector",
            "operation": "add_noise",
            "noise_level": 0.3
          },
          {
            "component": "VSABundle3",
            "operation": "robust_encoding",
            "num_vectors": 3
          },
          {
            "component": "VSASimilarity",
            "operation": "denoise_similarity",
            "threshold": 0.7
          },
          {
            "component": "AREngine",
            "operation": "robust_reasoning"
          }
        ],
        "noise_tolerance": 0.3,
        "similarity_threshold": 0.7
      },
      "expected_output": "Correct reasoning despite 30% noise"
    }
  ],

  "integration_examples": [
    {
      "name": "medical_diagnosis_composition",
      "use_case": "Medical diagnosis with neural features and AR rules",
      "components": ["CNN", "VSAEncoder", "RuleEngine", "XAIModule"],
      "flow": "Image → CNN → VSA encode → Rule check → Explain",
      "constraints": {
        "max_steps": 10,
        "min_confidence": 0.8,
        "safety_critical": true
      }
    },
    {
      "name": "legal_document_analysis",
      "use_case": "Legal document analysis with VSA semantic memory",
      "components": ["Transformer", "VSAEncoder", "VSASimilarity", "AREngine"],
      "flow": "Document → Embed → VSA encode → Retrieve → Reason",
      "constraints": {
        "similarity_threshold": 0.6,
        "max_retrievals": 5
      }
    },
    {
      "name": "autonomous_driving_decision",
      "use_case": "Autonomous driving with RL and VSA safety checks",
      "components": ["RL", "VSAEncoder", "RuleEngine", "Guardrails"],
      "flow": "Sensors → RL policy → VSA encode → Safety check → Act",
      "constraints": {
        "safety_critical": true,
        "max_steps": 5
      }
    }
  ]
}
